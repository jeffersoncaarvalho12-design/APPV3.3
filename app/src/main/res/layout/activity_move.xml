<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/green_light">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="18dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Saída / movimentação"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="@color/green_dark" />

        <EditText
            android:id="@+id/etBarcode"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:hint="Serial, MAC ou modelo" />

        <Button
            android:id="@+id/btnScanMove"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="Escanear pela câmera"
            android:textColor="@android:color/white"
            android:backgroundTint="@color/btn_scanner" />

        <Button
            android:id="@+id/btnSearchItem"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="Buscar item"
            android:textColor="@android:color/white"
            android:backgroundTint="@color/btn_move" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:orientation="vertical"
            android:background="@android:color/white"
            android:padding="14dp">

            <TextView
                android:id="@+id/tvItemName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nenhum item selecionado"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvItemStock"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Status atual: -" />
        </LinearLayout>

        <Spinner
            android:id="@+id/spinnerMovement"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp" />

        <Spinner
            android:id="@+id/spinnerMoveTechnician"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp" />

        <TextView
            android:id="@+id/tvPhotoStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@android:color/white"
            android:padding="12dp"
            android:text="Foto obrigatória na saída: pronto para integração" />

        <EditText
            android:id="@+id/etNote"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:hint="Observação" />

        <Button
            android:id="@+id/btnSendMove"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:text="Registrar movimentação"
            android:textColor="@android:color/white"
            android:backgroundTint="@color/btn_exit" />

        <ProgressBar
            android:id="@+id/progressMove"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:visibility="gone"
            android:layout_marginTop="12dp" />
    </LinearLayout>
</ScrollView>
